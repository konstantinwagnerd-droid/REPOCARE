# ================================================================
# CareAI — Environment Variables (Entwicklung & Produktion)
# ================================================================
# Alle Provider defaulten auf "mock" — Demo ist immer sicher.
# Real-Provider nur opt-in (meist über ENABLE_REAL_LLM=true).
# ================================================================

# ---- Database --------------------------------------------------
# Prod: Postgres (Supabase Transaction Pooler — IPv4-faehig, IPv6 nicht).
# Dev: PGlite embedded.
# WICHTIG: Hostname-Format beachten! Supabase Frankfurt = aws-1-eu-central-1
# (NICHT aws-0). Aktuelle Region siehst du im Connect-Modal deines Projekts.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
PGLITE_PATH="./local.db"

# ---- Setup-Token ----------------------------------------------
# Schuetzt /api/setup gegen unbefugten Schema-Reset.
SETUP_TOKEN="careai-setup-2026"

# ---- Owner-Account (wird bei /api/setup angelegt) -------------
# Versteckter Super-Admin-Account, nicht in der UI sichtbar.
OWNER_EMAIL="konstantin@careai.health"
OWNER_PASSWORD="Koko16!!"
OWNER_NAME="Konstantin Wagner"

# ---- Auth ------------------------------------------------------
# Generieren: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ---- Struktur-LLM (SIS-Strukturierung, Zusammenfassungen) -----
# LLM_PROVIDER: mock | anthropic | openai
# Wird in Vercel gesetzt über: Settings → Environment Variables.
LLM_PROVIDER="mock"
ENABLE_REAL_LLM="false"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-4-7-sonnet-20250929"
ANTHROPIC_BASE_URL=""
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"
# Monats-Budget in EUR — Kosten-Tracker alarmiert bei Überschreitung.
LLM_COST_BUDGET_EUR_PER_MONTH="50"
# PII aus Anfragen scrubben (Namen/SVN/Iban). Default: true.
LLM_SCRUB_PII="true"
# Nur true setzen wenn US-Endpoint bewusst akzeptiert wird.
ALLOW_US_OPENAI="false"

# ---- Voice / Transkription -----------------------------------
# WHISPER_PROVIDER: mock | openai | elevenlabs
# - openai     → Whisper-1 via OPENAI_API_KEY (oben).
# - elevenlabs → Scribe (EU-hosted), benötigt ELEVENLABS_API_KEY.
# In Vercel setzen: Settings → Environment Variables.
WHISPER_PROVIDER="mock"
WHISPER_MODEL="whisper-1"
ELEVENLABS_API_KEY=""
ELEVENLABS_MODEL="scribe_v1"

# ---- Email ----------------------------------------------------
# EMAIL_PROVIDER: mock | resend | postmark | smtp
EMAIL_PROVIDER="mock"
EMAIL_FROM="CareAI <noreply@careai.health>"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
POSTMARK_TOKEN=""
POSTMARK_STREAM="outbound"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
UNSUBSCRIBE_SECRET=""

# ---- Storage --------------------------------------------------
# STORAGE_PROVIDER: local | s3
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./storage"
S3_ENDPOINT="https://fsn1.your-objectstorage.com"
S3_REGION="eu-central"
S3_BUCKET="careai-production"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
# AES-256-GCM Encryption für sensitive Dateien. openssl rand -hex 32.
STORAGE_ENCRYPTION_KEY=""

# ---- Observability -------------------------------------------
LOG_LEVEL="info"
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
APP_VERSION="dev"

# ---- Infrastructure (Docker Compose) -------------------------
POSTGRES_PASSWORD=""
REDIS_PASSWORD=""
REDIS_URL="redis://localhost:6379"
ACME_EMAIL="ops@careai.health"
APP_DOMAIN="app.careai.health"
KUMA_DOMAIN="status.careai.health"

# ---- Feature Flags -------------------------------------------
ENABLE_PUSH_NOTIFICATIONS="false"
