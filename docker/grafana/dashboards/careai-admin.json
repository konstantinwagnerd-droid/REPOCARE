{
  "title": "CareAI — Admin & Security",
  "uid": "careai-admin",
  "tags": ["careai", "admin", "security"],
  "timezone": "Europe/Vienna",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    { "id": 1, "title": "Audit-Log Events / min", "type": "timeseries",
      "gridPos": {"x":0,"y":0,"w":12,"h":8},
      "targets": [{ "expr": "sum by (action) (rate(careai_audit_events_total[1m])) * 60", "refId": "A", "legendFormat": "{{action}}" }] },
    { "id": 2, "title": "Login-Rate (Erfolg)", "type": "timeseries",
      "gridPos": {"x":12,"y":0,"w":12,"h":8},
      "targets": [{ "expr": "sum(rate(careai_auth_login_success_total[5m]))", "refId": "A" }] },
    { "id": 3, "title": "Failed Logins (5m)", "type": "stat",
      "gridPos": {"x":0,"y":8,"w":6,"h":4},
      "targets": [{ "expr": "sum(increase(careai_auth_login_failed_total[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode":"absolute", "steps": [{"color":"green","value":0},{"color":"yellow","value":5},{"color":"red","value":20}] } } } },
    { "id": 4, "title": "Feature-Flag Changes (24h)", "type": "stat",
      "gridPos": {"x":6,"y":8,"w":6,"h":4},
      "targets": [{ "expr": "sum(increase(careai_feature_flag_changes_total[24h]))", "refId": "A" }] },
    { "id": 5, "title": "Impersonation-Sessions aktiv", "type": "stat",
      "gridPos": {"x":12,"y":8,"w":6,"h":4},
      "targets": [{ "expr": "careai_impersonation_active", "refId": "A" }] },
    { "id": 6, "title": "Webhook-Deliveries (OK/FAIL)", "type": "timeseries",
      "gridPos": {"x":18,"y":8,"w":6,"h":8},
      "targets": [{ "expr": "sum by (status) (rate(careai_webhook_deliveries_total[5m]))", "refId": "A", "legendFormat": "{{status}}" }] }
  ]
}
