# React 19 RC + viele Packages die noch React 18 als Peer-Dep deklarieren.
# legacy-peer-deps=true sagt npm: ignoriere Peer-Conflicts (npm v3-Verhalten).
# Sicher hier weil wir React 19 RC bewusst nutzen und alle UI-Libs damit arbeiten.
legacy-peer-deps=true

# Schnellere CI-Installs
fund=false
audit=false

# Strikte Engine-Checks — bricht fruehzeitig statt mit kryptischen Runtime-Fehlern
engine-strict=false

# Optional Deps koennen fehlschlagen ohne Build zu killen (jsforce, nodemailer, @sentry, etc.)
optional=true
